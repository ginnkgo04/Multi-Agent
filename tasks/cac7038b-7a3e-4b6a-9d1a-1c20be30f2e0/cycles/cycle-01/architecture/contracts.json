{
  "html_contract": {
    "required_elements": ["<!DOCTYPE html>", "<html lang=\"en\">", "<head>", "<title>Cherry Blossoms Introduction</title>", "<link rel=\"stylesheet\" href=\"style.css\">", "<body>", "<header>", "<nav>", "<main>", "<footer>"],
    "semantic_structure": {
      "header": "Must contain <h1> for title and <nav> with at least 3 links",
      "main": "Must contain at least two <section> elements with content",
      "footer": "Must contain copyright information"
    },
    "accessibility": {
      "lang_attribute": "en",
      "image_alt": "Required for all <img> elements",
      "aria_labels": "Optional but recommended for navigation"
    }
  },
  "css_contract": {
    "required_selectors": ["body", "header", "nav", "main", "footer", "@media queries"],
    "color_palette": {
      "primary": "#ffb6c1",
      "secondary": "#ffffff",
      "accent": "#d87093",
      "text": "#333333"
    },
    "responsive_breakpoints": {
      "mobile": "max-width: 768px",
      "tablet": "min-width: 769px and max-width: 1024px",
      "desktop": "min-width: 1025px"
    },
    "typography": {
      "font_family": "Arial, sans-serif",
      "base_size": "16px",
      "line_height": "1.6"
    }
  },
  "file_structure": {
    "required_files": ["index.html", "style.css", "cherry-blossom.jpg"],
    "directory": "All files must be in the same root directory",
    "naming_conventions": {
      "html": "index.html",
      "css": "style.css",
      "images": "Lowercase with hyphens"
    }
  }
}