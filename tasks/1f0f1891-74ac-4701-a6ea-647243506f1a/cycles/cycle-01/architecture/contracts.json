{
  "project": "Wuhan Specialty Snacks Webpage",
  "version": "1.0.0",
  "description": "Interface definitions and design system contracts for the Wuhan snacks static webpage",
  "last_updated": "2023-10-15",
  
  "interfaces": {
    "file_structure": {
      "index.html": {
        "purpose": "Main entry point with semantic HTML structure",
        "required_sections": ["header", "main", "footer"],
        "doctype": "HTML5",
        "character_encoding": "UTF-8",
        "viewport_meta": "required",
        "language": "en"
      },
      "css/": {
        "styles.css": {
          "purpose": "Primary stylesheet with responsive design",
          "methodology": "BEM (Block Element Modifier)",
          "organization": "Mobile-first, organized by component"
        },
        "reset.css": {
          "purpose": "CSS reset for consistent baseline across browsers",
          "based_on": "Modern reset with custom enhancements"
        }
      },
      "images/": {
        "purpose": "Directory for snack images and icons",
        "formats": ["jpg", "png", "svg"],
        "optimization": "Web-optimized, responsive sizes",
        "naming_convention": "kebab-case"
      },
      "README.md": {
        "purpose": "Project documentation",
        "required_sections": ["Project Description", "Setup", "Usage", "Credits"]
      }
    },
    
    "content_sections": {
      "header": {
        "required_elements": ["site-title", "navigation"],
        "semantic_tag": "<header>",
        "accessibility": "ARIA landmarks, skip navigation link"
      },
      "hero": {
        "required_elements": ["headline", "introductory-text", "background-image"],
        "semantic_tag": "<section>",
        "aria_role": "banner"
      },
      "snacks": {
        "required_elements": ["section-heading", "snack-cards"],
        "semantic_tag": "<main>",
        "minimum_snacks": 5,
        "card_structure": ["image", "title", "description", "key-ingredients"]
      },
      "footer": {
        "required_elements": ["copyright", "attribution", "contact-info"],
        "semantic_tag": "<footer>",
        "aria_role": "contentinfo"
      }
    },
    
    "design_system": {
      "colors": {
        "primary": {
          "value": "#E63946",
          "usage": "Headings, important buttons, highlights",
          "contrast_ratio": "7:1 against white"
        },
        "secondary": {
          "value": "#F1FAEE",
          "usage": "Backgrounds, card backgrounds",
          "contrast_ratio": "4.5:1 against primary"
        },
        "accent": {
          "value": "#A8DADC",
          "usage": "Borders, subtle highlights",
          "contrast_ratio": "3:1 against secondary"
        },
        "text": {
          "primary": "#1D3557",
          "secondary": "#457B9D",
          "usage": "Main text and secondary text respectively"
        },
        "background": {
          "value": "#FFFFFF",
          "usage": "Main page background"
        }
      },
      
      "typography": {
        "font_families": {
          "heading": "'Montserrat', sans-serif",
          "body": "'Open Sans', sans-serif",
          "fallback": "sans-serif"
        },
        "scale": {
          "h1": "2.5rem",
          "h2": "2rem",
          "h3": "1.5rem",
          "body": "1rem",
          "small": "0.875rem"
        },
        "line_height": {
          "headings": "1.2",
          "body": "1.6"
        },
        "weights": {
          "regular": "400",
          "medium": "500",
          "bold": "700"
        }
      },
      
      "spacing": {
        "scale": {
          "xxs": "0.25rem",
          "xs": "0.5rem",
          "sm": "1rem",
          "md": "1.5rem",
          "lg": "2rem",
          "xl": "3rem",
          "xxl": "4rem"
        },
        "container_max_width": "1200px",
        "gutter": "1rem"
      },
      
      "breakpoints": {
        "mobile": {
          "min": "320px",
          "max": "767px",
          "container_width": "100%",
          "gutter": "1rem"
        },
        "tablet": {
          "min": "768px",
          "max": "1023px",
          "container_width": "90%",
          "gutter": "1.5rem"
        },
        "desktop": {
          "min": "1024px",
          "max": "none",
          "container_width": "1200px",
          "gutter": "2rem"
        }
      },
      
      "components": {
        "card": {
          "border_radius": "8px",
          "box_shadow": "0 2px 8px rgba(0,0,0,0.1)",
          "hover_effect": "scale(1.02) and shadow elevation",
          "padding": "1.5rem",
          "margin_bottom": "2rem"
        },
        "button": {
          "padding": "0.75rem 1.5rem",
          "border_radius": "4px",
          "border": "none",
          "transition": "all 0.3s ease"
        },
        "navigation": {
          "item_spacing": "1rem",
          "active_indicator": "underline with primary color",
          "hover_effect": "color change to primary"
        }
      }
    }
  },
  
  "accessibility_contracts": {
    "color_contrast": {
      "normal_text": "Minimum 4.5:1",
      "large_text": "Minimum 3:1",
      "interactive_elements": "Minimum 4.5:1"
    },
    "keyboard_navigation": {
      "focus_indicator": "Visible outline with 2px primary color",
      "tab_order": "Logical DOM order",
      "skip_links": "Required for main content"
    },
    "screen_reader": {
      "alt_text": "Required for all informative images",
      "aria_labels": "Required for interactive elements without text",
      "landmark_roles": "Required for main sections"
    }
  },
  
  "performance_contracts": {
    "page_load": {
      "first_contentful_paint": "<1.5s",
      "largest_contentful_paint": "<2.5s",
      "cumulative_layout_shift": "<0.1"
    },
    "assets": {
      "image_optimization": "WebP with JPEG fallback",
      "css_size": "<50KB uncompressed",
      "http_requests": "<10 for initial page load"
    }
  },
  
  "compatibility_contracts": {
    "browsers": {
      "chrome": "last 2 versions",
      "firefox": "last 2 versions",
      "safari": "last 2 versions",
      "edge": "last 2 versions"
    },
    "devices": {
      "mobile": "320px and up",
      "tablet": "768px and up",
      "desktop": "1024px and up"
    }
  },
  
  "validation_rules": {
    "html": "W3C Validator compliant",
    "css": "W3C CSS Validator compliant",
    "accessibility": "WCAG 2.1 AA compliant"
  }
}