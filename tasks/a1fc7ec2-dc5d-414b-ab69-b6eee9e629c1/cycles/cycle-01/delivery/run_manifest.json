{
  "project": {
    "name": "沙县小吃介绍网站",
    "version": "1.0.0",
    "description": "简洁风格的沙县小吃介绍网站",
    "repository": "https://github.com/example/shaxian-snacks-website",
    "license": "MIT"
  },
  "delivery_info": {
    "delivery_date": "2024-01-15",
    "delivery_engineer": "Delivery Engineer",
    "build_id": "SHAXIAN-20240115-001",
    "environment": "production"
  },
  "architecture": {
    "frontend": {
      "framework": "Next.js 14",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "icons": "Lucide React",
      "build_tool": "Next.js Build System"
    },
    "backend": {
      "framework": "FastAPI 0.104.1",
      "language": "Python 3.11+",
      "database": "None (Static Data)",
      "server": "Uvicorn"
    }
  },
  "deployment_configuration": {
    "frontend_deployment": {
      "platform": "Vercel (Recommended) / Netlify",
      "build_command": "npm run build",
      "output_directory": ".next",
      "environment_variables": {
        "NEXT_PUBLIC_API_URL": "https://api.shaxian-snacks.com",
        "NEXT_PUBLIC_GOOGLE_MAPS_KEY": "YOUR_GOOGLE_MAPS_API_KEY"
      },
      "domains": [
        "shaxian-snacks.com",
        "www.shaxian-snacks.com"
      ]
    },
    "backend_deployment": {
      "platform": "Railway (Recommended) / Render",
      "start_command": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "requirements_file": "requirements.txt",
      "environment_variables": {
        "ENVIRONMENT": "production",
        "CORS_ORIGINS": "https://shaxian-snacks.com,https://www.shaxian-snacks.com",
        "API_PREFIX": "/api"
      }
    }
  },
  "file_structure": {
    "frontend": {
      "root": "workspace/frontend/",
      "key_files": [
        "app/page.tsx",
        "app/layout.tsx",
        "app/globals.css",
        "components/FeatureExperience.tsx",
        "lib/api.ts",
        "package.json",
        "tailwind.config.ts",
        "next.config.js",
        "tsconfig.json"
      ],
      "build_output": ".next/",
      "public_assets": "public/"
    },
    "backend": {
      "root": "workspace/backend/",
      "key_files": [
        "app/main.py",
        "app/schemas.py",
        "app/services.py",
        "app/routes.py",
        "requirements.txt"
      ],
      "static_files": "static/"
    }
  },
  "api_endpoints": {
    "content": {
      "endpoint": "GET /api/content",
      "description": "获取网站完整内容",
      "response_schema": "WebsiteContent"
    },
    "menu": {
      "endpoint": "GET /api/menu",
      "description": "获取菜单项列表",
      "query_params": ["category", "limit"],
      "response_schema": "List[MenuItem]"
    },
    "locations": {
      "endpoint": "GET /api/locations",
      "description": "获取门店位置信息",
      "response_schema": "List[Location]"
    },
    "testimonials": {
      "endpoint": "GET /api/testimonials",
      "description": "获取客户评价",
      "response_schema": "List[Testimonial]"
    },
    "health": {
      "endpoint": "GET /api/health",
      "description": "健康检查端点",
      "response_schema": "HealthResponse"
    }
  },
