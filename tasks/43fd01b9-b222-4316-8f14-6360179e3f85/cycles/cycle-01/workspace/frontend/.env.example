# Pink Pig Website Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (Optional)
NEXT_PUBLIC_GA_TRACKING_ID=UA-XXXXXXXXX-X
NEXT_PUBLIC_HOTJAR_ID=0000000

# Social Media
NEXT_PUBLIC_TWITTER_HANDLE=@pinkpigworld
NEXT_PUBLIC_FACEBOOK_PAGE=https://facebook.com/pinkpigworld

# Feature Flags
NEXT_PUBLIC_ENABLE_SOUND=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SOCIAL_SHARE=true

# Development
NODE_ENV=development