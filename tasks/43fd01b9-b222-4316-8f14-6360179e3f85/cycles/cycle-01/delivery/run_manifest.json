{
  "project": {
    "name": "粉色小猪介绍网站",
    "version": "1.0.0",
    "description": "一个可爱、粉嫩的粉色小猪介绍单页网站",
    "repository": "https://github.com/example/pink-pig-website",
    "license": "MIT"
  },
  "delivery_info": {
    "delivery_date": "2024-01-15",
