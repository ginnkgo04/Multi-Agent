  "architecture": {
    "frontend": {
      "framework": "Next.js 14",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "icons": "Lucide React",
      "build_tool": "npm",
      "deployment_target": "Vercel / Node.js服务器"
    },
    "backend": {
      "framework": "FastAPI 0.104.1",
      "language": "Python 3.11+",
      "server": "Uvicorn",
      "validation": "Pydantic 2.5.0",
      "deployment_target": "任何支持Python的服务器"
    }
  },
  "build_configuration": {
    "frontend_build": {
      "command": "npm run build",
      "output_directory": ".next",
      "static_files": "public",
      "environment_variables": [
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_GA_TRACKING_ID"
      ]
    },
    "backend_setup": {
      "command": "pip install -r requirements.txt",
      "start_command": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "environment_variables": [
        "DATABASE_URL",
        "SECRET_KEY",
        "ALLOWED_ORIGINS"
      ]
    }
  },
  "deployment_targets": [
    {
      "name": "开发环境",
      "type": "本地开发",
      "frontend_url": "http://localhost:3000",
      "backend_url": "http://localhost:8000",
      "database": "SQLite (开发)",
      "notes": "用于本地开发和测试"
    },
    {
      "name": "生产环境",
      "type": "云部署",
      "frontend_url": "https://pinkpig.example.com",
      "backend_url": "https://api.pinkpig.example.com",
      "database": "PostgreSQL / MySQL",
      "notes": "生产环境部署建议"
    }
  ],
  "dependencies": {
    "frontend_dependencies": {
      "react": "^18",
      "react-dom": "^18",
      "next": "^14",
      "lucide-react": "^0.344.0",
      "class-variance-authority": "^0.7.0",
      "clsx": "^2.1.1",
      "tailwind-merge": "^2.2.0",
      "tailwindcss": "^3.3.0",
      "autoprefixer": "^10.4.0",
      "postcss": "^8.4.0",
      "typescript": "^5.0.0",
      "@types/node": "^20.0.0",
